{
    "name": "verdient/hyperf3-filesystem",
    "type": "library",
    "version": "1.0.1",
    "autoload": {
        "psr-4": {
            "Verdient\\Hyperf3\\Filesystem\\": "src"
        }
    },
    "extra": {
        "hyperf": {
            "config": "Verdient\\Hyperf3\\Filesystem\\ConfigProvider"
        }
    },
    "archive": {
        "exclude": [
            ".gitignore",
            "README.md"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "require": {
        "aliyuncs/oss-sdk-php": "^2.7",
        "hyperf/filesystem": "^3.1",
        "hyperf/flysystem-oss": "^1.4",
        "hyperf/support": "^3.1",
        "league/flysystem": "^3.33",
        "league/uri": "^7.8",
        "verdient/hyperf3-di": "^2.0"
    },
    "require-dev": {
        "jetbrains/phpstorm-attributes": "^1.2"
    }
}
